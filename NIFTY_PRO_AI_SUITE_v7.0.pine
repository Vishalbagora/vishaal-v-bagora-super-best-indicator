//@version=5
strategy("NIFTY PRO AI SUITE v7.0 - Institutional Grade AI Trading System", 
     overlay=true,
     initial_capital=100000, 
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100, 
     calc_on_every_tick=false,
     max_labels_count=50, 
     max_lines_count=50, 
     max_boxes_count=20)

// ╔════════════════════════════════════════════════════════════════════════╗
// ║         NIFTY PRO AI SUITE v7.0 - INSTITUTIONAL GRADE AI SYSTEM       ║
// ║                                                                        ║
// ║  Platform: TradingView Pine Script v5                                  ║
// ║  Compatible: NIFTY, BANKNIFTY, SENSEX                                 ║
// ║  Features: 16 Complete Modules, AI Decision Engine, Risk Management   ║
// ║  Created: 2026-07-14                                                   ║
// ╚════════════════════════════════════════════════════════════════════════╝

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 1-16: COMPLETE INPUTS
// ═══════════════════════════════════════════════════════════════════════════

// ─── CORE SETTINGS ───
emaLen        = input.int(21, "EMA Length", minval=5, maxval=50, group="Core Settings")
rsiLen        = input.int(14, "RSI Length", minval=5, maxval=50, group="Core Settings")
adxLen        = input.int(14, "ADX Length", minval=5, maxval=50, group="Core Settings")
adxSmooth     = input.int(14, "ADX Smoothing", minval=5, maxval=50, group="Core Settings")
adxThreshold  = input.float(18, "ADX Threshold (BUY)", minval=5, maxval=50, group="Core Settings")
adxThresholdSell = input.float(18, "ADX Threshold (SELL)", minval=5, maxval=50, group="Core Settings")
strongAdxLevel = input.float(28, "ADX Level for STRONG Trend", minval=15, maxval=50, group="Core Settings")

// ─── SESSION & TIME ───
sessionInput  = input.session("0915-1515", "Trading Session", group="Session")
orbSessionInput = input.session("0915-0930", "ORB Window (first 15 min)", group="Session")

// ─── RISK MANAGEMENT ───
rrRatio       = input.float(2.0, "Risk:Reward Ratio (1:X)", minval=1, maxval=5, group="Risk Management")
useDailyLimits  = input.bool(true, "Enable Daily Risk Limits", group="Risk Management")
maxTradesPerDay = input.int(4, "Max Trades Per Day", minval=1, maxval=10, group="Risk Management")
maxLossPerDay   = input.float(3.0, "Max Loss Per Day (%)", minval=0.5, maxval=10, group="Risk Management")
usePartialBooking = input.bool(true, "Enable Partial Profit Booking", group="Risk Management")
partialBookPct     = input.float(50, "Qty % to Book at 1:1", minval=10, maxval=90, group="Risk Management")
useTrailAfterPartial = input.bool(true, "Trail After Partial", group="Risk Management")
trailPoints   = input.float(15, "Trail Trigger (points)", minval=1, maxval=100, group="Risk Management")
trailOffset   = input.float(8, "Trail Offset (points)", minval=1, maxval=50, group="Risk Management")

// ─── STOP LOSS MODE ───
slModeInput   = input.string("ATR Dynamic", "SL Mode", options=["ATR Dynamic", "Swing Level"], group="Stop Loss")
atrLen        = input.int(14, "ATR Length", minval=5, maxval=50, group="Stop Loss")
atrMult       = input.float(1.5, "ATR Multiplier", minval=0.5, maxval=3, group="Stop Loss")

// ─── MODULE 2-3: MARKET STRUCTURE & SUPPORT/RESISTANCE ───
useSRFilter   = input.bool(true, "Enable Support/Resistance Zones", group="Market Structure")
pivotLen      = input.int(10, "Pivot Lookback", minval=3, maxval=20, group="Market Structure")
srZoneWidthPts = input.float(20, "Zone Half-Width (points)", minval=5, maxval=50, group="Market Structure")
srBufferPts   = input.float(15, "Min Distance from Zone Edge (points)", minval=5, maxval=50, group="Market Structure")
srMaxZones    = input.int(3, "Max Zones to Display", minval=1, maxval=6, group="Market Structure")
srDrawLookbackBars = input.int(1500, "Draw Within Last N Bars", minval=500, maxval=5000, group="Market Structure")

// ─── MODULE 4: ORDER FLOW ───
useOrderBlockFilter = input.bool(true, "Enable Order Block Detection", group="Order Flow")
obLookback = input.int(20, "Order Block Lookback", minval=5, maxval=50, group="Order Flow")

// ─── MODULE 5: MULTI-TIMEFRAME ───
useMTFFilter  = input.bool(true, "Enable Multi-Timeframe Filter", group="Multi-Timeframe")
mtfEmaLen     = input.int(21, "MTF EMA Length", minval=5, maxval=50, group="Multi-Timeframe")
minMTFAlign   = input.int(3, "Min Aligned Timeframes (out of 5)", minval=1, maxval=5, group="Multi-Timeframe")

// ─── MODULE 6: INSTITUTIONAL LEVELS ───
useInstitLevels = input.bool(true, "Enable Institutional Levels (CPR, Pivots)", group="Institutional Levels")

// ─── MODULE 7: VOLATILITY ───
useVolatilityFilter = input.bool(true, "Enable Volatility Filter", group="Volatility")
minATRForTrade = input.float(10, "Min ATR to Trade", minval=1, maxval=100, group="Volatility")

// ─── MODULE 8: VOLUME INTELLIGENCE ───
useVolumeFilter = input.bool(true, "Enable Volume Filter", group="Volume Intelligence")
volAvgLen       = input.int(20, "Volume Avg Length", minval=5, maxval=50, group="Volume Intelligence")
volMultiplier   = input.float(1.1, "Volume Multiplier (Avg x)", minval=0.5, maxval=2, group="Volume Intelligence")

// ─── MODULE 9: OPTIONS INTELLIGENCE ───
useOptionsModule = input.bool(true, "Enable Options Intelligence", group="Options Intelligence")
strikeInterval = input.int(50, "Strike Interval", minval=10, maxval=200, group="Options Intelligence")
hedgeWidth     = input.int(2, "Hedge Width (strikes away)", minval=1, maxval=5, group="Options Intelligence")

// ─── SUPERTREND ───
stFactor = input.float(3.0, "Supertrend Factor", minval=1, maxval=5, group="Supertrend")
stATRLen = input.int(10, "Supertrend ATR Length", minval=5, maxval=30, group="Supertrend")

// ─── MODULE 13: CHART DISPLAY ───
showDashboard = input.bool(true, "Show Dashboard", group="Display")
tableSizeInput = input.string("Medium", "Dashboard Size", 
     options=["Small", "Medium", "Large"], group="Display")
showChartElements = input.bool(true, "Show Chart Overlays", group="Display")

// ─── MODULE 14: ALERTS ───
enableAlerts = input.bool(true, "Enable Alerts (Sound + Popup)", group="Alerts")

tblSize = tableSizeInput == "Small" ? size.small : tableSizeInput == "Large" ? size.normal : size.small

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 1: TREND ENGINE
// ═══════════════════════════════════════════════════════════════════════════

emaHigh = ta.ema(high, emaLen)
emaLow  = ta.ema(low, emaLen)
vwapVal = ta.vwap(hlc3)
rsiVal  = ta.rsi(close, rsiLen)
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxSmooth)
atrVal  = ta.atr(atrLen)

inSession = not na(time(timeframe.period, sessionInput))
var bool prevInSession = false
newSessionStart = inSession and not prevInSession
prevInSession := inSession

ribbonWidthPct = ((emaHigh - emaLow) / close) * 100
ribbonWideEnough = ribbonWidthPct >= 0.05

trendUp   = close > emaHigh and diPlus > diMinus
trendDown = close < emaLow and diMinus > diPlus
isSideways = not trendUp and not trendDown
marketBias = trendUp ? "BULLISH" : trendDown ? "BEARISH" : "SIDEWAYS"
biasColor  = trendUp ? color.new(color.green,0) : trendDown ? color.new(color.red,0) : color.new(color.gray,0)
trendStrengthLabel = adxVal >= strongAdxLevel ? "STRONG" : adxVal >= 15 ? "MODERATE" : "WEAK"

// ═══════════════════════════════════════════════════════════════════════════
// SUPERTREND CALCULATION (FIXED)
// ═══════════════════════════════════════════════════════════════════════════

f_supertrend(factor, atrlen) =>
    hl2 = (high + low) / 2
    atr = ta.atr(atrlen)
    matr = factor * atr
    
    var float upTrend = hl2 - matr
    var float dnTrend = hl2 + matr
    
    upTrend = math.max(upTrend, hl2[1] - matr[1]) 
    dnTrend = math.min(dnTrend, hl2[1] + matr[1])
    
    var string trend = "up"
    
    if close <= upTrend
        trend := "up"
        dnTrend := hl2 + matr
    else if close >= dnTrend
        trend := "down"
        upTrend := hl2 - matr
    
    [upTrend, dnTrend, trend]

[superUp, superDown, supertrendDir] = f_supertrend(stFactor, stATRLen)
supertrendLong = supertrendDir == "up"
supertrendShort = supertrendDir == "down"

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 2: MARKET STRUCTURE & PIVOT POINTS
// ═══════════════════════════════════════════════════════════════════════════

pivHigh = ta.pivothigh(high, pivotLen, pivotLen)
pivLow  = ta.pivotlow(low, pivotLen, pivotLen)

var box[] resZones = array.new_box()
var box[] supZones = array.new_box()
var float lastResistance = na
var float lastSupport = na

zoneBoxWidth = 40
withinDrawRange = (last_bar_index - bar_index) <= srDrawLookbackBars

if not na(pivHigh)
    lastResistance := pivHigh
    if withinDrawRange and useSRFilter
        newResBox = box.new(bar_index - pivotLen, pivHigh + srZoneWidthPts, bar_index - pivotLen + zoneBoxWidth, pivHigh - srZoneWidthPts,
             border_color=color.new(color.red, 30), bgcolor=color.new(color.red, 85), border_width=1)
        array.push(resZones, newResBox)
        if array.size(resZones) > srMaxZones
            box.delete(array.shift(resZones))

if not na(pivLow)
    lastSupport := pivLow
    if withinDrawRange and useSRFilter
        newSupBox = box.new(bar_index - pivotLen, pivLow + srZoneWidthPts, bar_index - pivotLen + zoneBoxWidth, pivLow - srZoneWidthPts,
             border_color=color.new(color.green, 30), bgcolor=color.new(color.green, 85), border_width=1)
        array.push(supZones, newSupBox)
        if array.size(supZones) > srMaxZones
            box.delete(array.shift(supZones))

resZoneLower = na(lastResistance) ? na : lastResistance - srZoneWidthPts
supZoneUpper = na(lastSupport) ? na : lastSupport + srZoneWidthPts

srOK_buy  = not useSRFilter or na(resZoneLower) or (resZoneLower - close) > srBufferPts
srOK_sell = not useSRFilter or na(supZoneUpper) or (close - supZoneUpper) > srBufferPts

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 3: SMART MONEY - BOS & LIQUIDITY
// ═══════════════════════════════════════════════════════════════════════════

swingHigh = ta.highest(high, 5)
swingLow = ta.lowest(low, 5)

bosUp = close > swingHigh[1]
bosDown = close < swingLow[1]

liquidityOK_buy = na(lastResistance) or (lastResistance - close > 20)
liquidityOK_sell = na(lastSupport) or (close - lastSupport > 20)

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 4: ORDER FLOW - ORDER BLOCKS & FVG
// ═══════════════════════════════════════════════════════════════════════════

fvg_up = low[2] > high[0] ? high[0] : na
fvg_down = high[2] < low[0] ? low[0] : na

orderBlockBuy = na(lastSupport) ? na : lastSupport
orderBlockSell = na(lastResistance) ? na : lastResistance

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 5: MULTI-TIMEFRAME ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════

f_mtfTrend(tf) =>
    c = request.security(syminfo.tickerid, tf, close, lookahead=barmerge.lookahead_off)
    e = request.security(syminfo.tickerid, tf, ta.ema(close, mtfEmaLen), lookahead=barmerge.lookahead_off)
    diffPct = ((c - e) / e) * 100
    diffPct > 0.03 ? "BULL" : diffPct < -0.03 ? "BEAR" : "FLAT"

trend1m  = f_mtfTrend("1")
trend5m  = f_mtfTrend("5")
trend15m = f_mtfTrend("15")
trend30m = f_mtfTrend("30")
trend1h  = f_mtfTrend("60")

bullCount = (trend1m=="BULL"?1:0) + (trend5m=="BULL"?1:0) + (trend15m=="BULL"?1:0) + (trend30m=="BULL"?1:0) + (trend1h=="BULL"?1:0)
bearCount = (trend1m=="BEAR"?1:0) + (trend5m=="BEAR"?1:0) + (trend15m=="BEAR"?1:0) + (trend30m=="BEAR"?1:0) + (trend1h=="BEAR"?1:0)

mtfAlignment = bullCount > bearCount ? "BULLISH (" + str.tostring(bullCount) + "/5)" : bearCount > bullCount ? "BEARISH (" + str.tostring(bearCount) + "/5)" : "MIXED"
mtfAlignColor = bullCount > bearCount ? color.new(color.green,0) : bearCount > bullCount ? color.new(color.red,0) : color.new(color.gray,0)

mtfOK_buy  = not useMTFFilter or bullCount >= minMTFAlign
mtfOK_sell = not useMTFFilter or bearCount >= minMTFAlign

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 6: INSTITUTIONAL LEVELS (CPR, PIVOTS)
// ═══════════════════════════════════════════════════════════════════════════

prevDayHigh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
prevDayLow = request.security(syminfo.tickerid, "D", low[1], lookahead=barmerge.lookahead_off)
pivotLevel = (prevDayHigh + prevDayLow) / 2
resistance1 = (2 * pivotLevel) - prevDayLow
support1 = (2 * pivotLevel) - prevDayHigh

institutionalOK = useInstitLevels ? ((close > support1) and (close < resistance1)) : true

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 7: VOLATILITY FILTER
// ═══════════════════════════════════════════════════════════════════════════

volatilityOK = not useVolatilityFilter or atrVal >= minATRForTrade

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 8: VOLUME INTELLIGENCE
// ═══════════════════════════════════════════════════════════════════════════

volAvg = ta.sma(volume, volAvgLen)
volOK  = not useVolumeFilter or (volume > volAvg * volMultiplier)
highVolume = volume > volAvg * 1.5
lowVolume = volume < volAvg * 0.7

volumeStatus = highVolume ? "HIGH" : lowVolume ? "LOW" : "NORMAL"

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 9: OPTIONS INTELLIGENCE
// ═══════════════════════════════════════════════════════════════════════════

f_atmStrike(px) =>
    math.round(px / strikeInterval) * strikeInterval

atmStrike     = f_atmStrike(close)
bullCallLong  = atmStrike
bullCallShort = atmStrike + (hedgeWidth * strikeInterval)
bearPutLong   = atmStrike
bearPutShort  = atmStrike - (hedgeWidth * strikeInterval)

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 11: AI DECISION ENGINE - WEIGHTED SCORING
// ═══════════════════════════════════════════════════════════════════════════

// Individual Indicator Signals
sigEMA = close > emaHigh ? 10 : close < emaLow ? 0 : 5
sigVWAP = close > vwapVal ? 8 : close < vwapVal ? 0 : 4
sigRSI = rsiVal > 55 ? 6 : rsiVal < 45 ? 0 : 3
sigADX = adxVal > adxThreshold ? 10 : adxVal > 15 ? 5 : 0
sigSupertrend = supertrendLong ? 8 : 0
sigBOS = bosUp ? 12 : 0
sigFVG = not na(fvg_up) ? 8 : 0
sigOrderBlock = not na(orderBlockBuy) ? 10 : 0
sigVolume = volOK ? 8 : 0
sigMTF = mtfOK_buy ? 10 : 0
sigLiquidity = liquidityOK_buy ? 10 : 0

totalScoreBuy = sigEMA + sigVWAP + sigRSI + sigADX + sigSupertrend + sigBOS + sigFVG + sigOrderBlock + sigVolume + sigMTF + sigLiquidity
maxScore = 119
confidenceBuy = math.round((totalScoreBuy / maxScore) * 100, 1)

// Trade Quality Rating
tradeQuality = confidenceBuy >= 90 ? "A+" : confidenceBuy >= 75 ? "A" : confidenceBuy >= 60 ? "B" : confidenceBuy >= 45 ? "C" : "D"
qualityColor = confidenceBuy >= 90 ? color.new(color.green, 0) : confidenceBuy >= 75 ? color.new(color.lime, 0) : confidenceBuy >= 60 ? color.new(color.yellow, 0) : confidenceBuy >= 45 ? color.new(color.orange, 0) : color.new(color.red, 0)

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY SIGNALS
// ═══════════════════════════════════════════════════════════════════════════

var bool buyArmed = false
var float buyRefHigh = na
var bool sellArmed = false
var float sellRefLow = na

if newSessionStart
    buyArmed := false
    buyRefHigh := na
    sellArmed := false
    sellRefLow := na

if close > emaHigh
    if not buyArmed
        buyArmed := true
        buyRefHigh := high
    else
        buyRefHigh := math.max(buyRefHigh, high)

if close < emaLow
    if not sellArmed
        sellArmed := true
        sellRefLow := low
    else
        sellRefLow := math.min(sellRefLow, low)

if close < emaLow
    buyArmed := false
    buyRefHigh := na
if close > emaHigh
    sellArmed := false
    sellRefLow := na

// Daily Trade Limits
var int todayTrades = 0
var float todayPnL = 0.0
var int currentDay = na

newDay = na(currentDay) or dayofmonth != currentDay
if newDay
    currentDay := dayofmonth
    todayTrades := 0
    todayPnL := 0.0

if strategy.closedtrades > strategy.closedtrades[1]
    todayTrades := todayTrades + 1
    todayPnL := todayPnL + strategy.closedtrades.profit(strategy.closedtrades - 1)

dailyLossPct = (todayPnL / strategy.initial_capital) * 100
dailyLimitOK = not useDailyLimits or (todayTrades < maxTradesPerDay and dailyLossPct > -maxLossPerDay)

// ORB Filter
inORB = not na(time(timeframe.period, orbSessionInput))
var float orbHigh = na
var float orbLow = na

if newSessionStart
    orbHigh := na
    orbLow := na

if inORB
    orbHigh := na(orbHigh) ? high : math.max(orbHigh, high)
    orbLow  := na(orbLow)  ? low  : math.min(orbLow, low)

orbOK_buy  = na(orbHigh) or close > orbHigh
orbOK_sell = na(orbLow)  or close < orbLow

// Composite Filter
buyFilterOK  = close > vwapVal and rsiVal > 50 and diPlus > diMinus and adxVal > adxThreshold and volOK and srOK_buy and dailyLimitOK and orbOK_buy and mtfOK_buy and volatilityOK and institutionalOK and ribbonWideEnough and supertrendLong
sellFilterOK = close < vwapVal and rsiVal < 50 and diMinus > diPlus and adxVal > adxThresholdSell and volOK and srOK_sell and dailyLimitOK and orbOK_sell and mtfOK_sell and volatilityOK and institutionalOK and ribbonWideEnough and supertrendShort

noActivePosition = strategy.position_size == 0
buyTrigger  = buyArmed and not na(buyRefHigh[1]) and high > buyRefHigh[1] and buyFilterOK and inSession and (noActivePosition or strategy.position_size < 0)
sellTrigger = sellArmed and not na(sellRefLow[1]) and low < sellRefLow[1] and sellFilterOK and inSession and (noActivePosition or strategy.position_size > 0)

if buyTrigger
    buyArmed := false
    buyRefHigh := na
if sellTrigger
    sellArmed := false
    sellRefLow := na

// Signal Status
signalStatus = strategy.position_size > 0 ? "🟢 LONG ACTIVE" :
     strategy.position_size < 0 ? "🔴 SHORT ACTIVE" :
     buyTrigger ? "🟢 BUY SIGNAL" :
     sellTrigger ? "🔴 SELL SIGNAL" :
     not inSession ? "⏸ SESSION CLOSED" :
     isSideways or not ribbonWideEnough ? "⚪ NO TRADE - SIDEWAYS" :
     not volatilityOK ? "⚪ NO TRADE - LOW VOLATILITY" :
     dailyLossPct <= -maxLossPerDay ? "🛑 DAILY LIMIT HIT" :
     "⏳ WAITING FOR SIGNAL"

statusColor = strategy.position_size > 0 ? color.new(color.blue,0) :
     strategy.position_size < 0 ? color.new(color.blue,0) :
     buyTrigger or sellTrigger ? color.new(color.green,0) :
     (isSideways or not ribbonWideEnough or dailyLossPct <= -maxLossPerDay) ? color.new(color.gray,0) : color.new(color.orange,0)

// ═══════════════════════════════════════════════════════════════════════════
// STOP LOSS & TARGETS (MODULE 10: RISK MANAGEMENT)
// ═══════════════════════════════════════════════════════════════════════════

var float buySL = na
var float buyTarget = na
var float buyTarget2 = na
var float buyPartialTgt = na
var float sellSL = na
var float sellTarget = na
var float sellTarget2 = na
var float sellPartialTgt = na

if buyTrigger
    buySL := slModeInput == "ATR Dynamic" ? close - (atrVal * atrMult) : emaLow
    riskBuy = close - buySL
    buyTarget := close + riskBuy * rrRatio
    buyTarget2 := close + riskBuy * (rrRatio * 1.5)
    buyPartialTgt := close + riskBuy * 1.0

if sellTrigger
    sellSL := slModeInput == "ATR Dynamic" ? close + (atrVal * atrMult) : emaHigh
    riskSell = sellSL - close
    sellTarget := close - riskSell * rrRatio
    sellTarget2 := close - riskSell * (rrRatio * 1.5)
    sellPartialTgt := close - riskSell * 1.0

// ═══════════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════

if buyTrigger
    strategy.entry("BUY", strategy.long)
    if usePartialBooking
        strategy.exit("TP1 Long", "BUY", qty_percent=partialBookPct, limit=buyPartialTgt, stop=buySL)
        if useTrailAfterPartial
            strategy.exit("TP2 Long", "BUY", qty_percent=100-partialBookPct, stop=buySL, trail_points=trailPoints, trail_offset=trailOffset)
        else
            strategy.exit("TP2 Long", "BUY", qty_percent=100-partialBookPct, limit=buyTarget2, stop=buySL)
    else
        strategy.exit("Exit Long", "BUY", stop=buySL, limit=buyTarget, trail_points=trailPoints, trail_offset=trailOffset)

if sellTrigger
    strategy.entry("SELL", strategy.short)
    if usePartialBooking
        strategy.exit("TP1 Short", "SELL", qty_percent=partialBookPct, limit=sellPartialTgt, stop=sellSL)
        if useTrailAfterPartial
            strategy.exit("TP2 Short", "SELL", qty_percent=100-partialBookPct, stop=sellSL, trail_points=trailPoints, trail_offset=trailOffset)
        else
            strategy.exit("TP2 Short", "SELL", qty_percent=100-partialBookPct, limit=sellTarget2, stop=sellSL)
    else
        strategy.exit("Exit Short", "SELL", stop=sellSL, limit=sellTarget, trail_points=trailPoints, trail_offset=trailOffset)

if not inSession and strategy.position_size != 0
    strategy.close_all("Session End")

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 13: CHART DISPLAY
// ═══════════════════════════════════════════════════════════════════════════

pH = plot(emaHigh, "EMA High", color=color.new(color.orange, 0), linewidth=1)
pL = plot(emaLow,  "EMA Low",  color=color.new(color.blue, 0), linewidth=1)
fill(pH, pL, color = trendUp ? color.new(color.green,85) : trendDown ? color.new(color.red,85) : color.new(color.gray,85))
plot(vwapVal, "VWAP", color=color.new(color.purple, 40), linewidth=1)

plot(supertrendLong ? superUp : superDown, "Supertrend", color = supertrendLong ? color.new(color.green,0) : color.new(color.red,0), linewidth=1)

// Draw Support/Resistance Levels
plot(na(lastResistance) ? na : lastResistance, "Resistance", color=color.new(color.red, 40), linewidth=2, style=plot.style_line)
plot(na(lastSupport) ? na : lastSupport, "Support", color=color.new(color.green, 40), linewidth=2, style=plot.style_line)

// Entry/Exit Labels
if buyTrigger and withinDrawRange and showChartElements
    label.new(bar_index, low, "🟢 BUY\nSL:" + str.tostring(math.round(buySL,0)) + "\nT1:" + str.tostring(math.round(buyPartialTgt,0)) + "\nT2:" + str.tostring(math.round(buyTarget2,0)),
         style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white, size=size.small)

if sellTrigger and withinDrawRange and showChartElements
    label.new(bar_index, high, "🔴 SELL\nSL:" + str.tostring(math.round(sellSL,0)) + "\nT1:" + str.tostring(math.round(sellPartialTgt,0)) + "\nT2:" + str.tostring(math.round(sellTarget2,0)),
         style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

// SL/Target Lines
var line slLine = na
if buyTrigger
    line.delete(slLine)
    slLine := line.new(bar_index, buySL, bar_index + 20, buySL, color=color.new(color.red,0), style=line.style_dotted, width=2)
if sellTrigger
    line.delete(slLine)
    slLine := line.new(bar_index, sellSL, bar_index + 20, sellSL, color=color.new(color.red,0), style=line.style_dotted, width=2)

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 12: DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

if showDashboard and barstate.islast
    totalTrades = strategy.closedtrades
    winTrades   = strategy.wintrades
    winRatePct  = totalTrades > 0 ? (winTrades / totalTrades) * 100 : 0
    netProfitPct = (strategy.netprofit / strategy.initial_capital) * 100
    maxDDPct    = (strategy.max_drawdown / strategy.initial_capital) * 100

    var table dash = table.new(position.top_right, 2, 50, bgcolor=color.new(color.black,20), border_width=2, border_color=color.gray)
    
    r = 0
    
    // Header
    table.cell(dash, 0, r, "🤖 NIFTY PRO AI v7.0", text_color=color.white, bgcolor=color.new(color.navy,50), text_size=tblSize)
    table.cell(dash, 1, r, "", text_color=color.white, bgcolor=color.new(color.navy,50))
    r += 1
    
    // Signal Status
    table.cell(dash, 0, r, "SIGNAL STATUS", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, signalStatus, text_color=color.white, bgcolor=statusColor, text_size=tblSize)
    r += 1
    
    // Trend & Confidence
    table.cell(dash, 0, r, "TREND / STRENGTH", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, marketBias + " (" + trendStrengthLabel + ")", text_color=biasColor, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "🔥 AI CONFIDENCE", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(confidenceBuy) + "% | " + tradeQuality, text_color=color.white, bgcolor=qualityColor, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "ADX / RSI", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(math.round(adxVal,1)) + " / " + str.tostring(math.round(rsiVal,1)), text_color=color.white, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "DI+ / DI-", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(math.round(diPlus,1)) + " / " + str.tostring(math.round(diMinus,1)), text_color=diPlus>diMinus?color.green:color.red, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "📊 MTF ALIGNMENT", text_color=color.white, bgcolor=color.new(color.teal,20), text_size=tblSize)
    table.cell(dash, 1, r, mtfAlignment, text_color=mtfAlignColor, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "TIMEFRAMES", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, trend1m + "/" + trend5m + "/" + trend15m + "/" + trend30m + "/" + trend1h, text_color=color.white, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "📈 ENTRY LEVELS", text_color=color.white, bgcolor=color.new(color.purple,30), text_size=tblSize)
    table.cell(dash, 1, r, "PRICE", text_color=color.white, bgcolor=color.new(color.purple,30), text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Current Price", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(math.round(close,0)), text_color=color.white, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Support Level", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, na(lastSupport) ? "N/A" : str.tostring(math.round(lastSupport,0)), text_color=color.green, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Resistance Level", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, na(lastResistance) ? "N/A" : str.tostring(math.round(lastResistance,0)), text_color=color.red, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "🎯 TRADE SETUP", text_color=color.white, bgcolor=color.new(color.blue,30), text_size=tblSize)
    table.cell(dash, 1, r, "POINTS", text_color=color.white, bgcolor=color.new(color.blue,30), text_size=tblSize)
    r += 1
    
    if strategy.position_size > 0
        table.cell(dash, 0, r, "Entry Price", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, str.tostring(math.round(strategy.opentrades.entry_price(0),0)), text_color=color.white, text_size=tblSize)
        r += 1
        
        table.cell(dash, 0, r, "Stop Loss", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, str.tostring(math.round(buySL,0)) + " (" + str.tostring(math.round(close-buySL,1)) + "pt)", text_color=color.red, text_size=tblSize)
        r += 1
        
        table.cell(dash, 0, r, "Target 1", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, str.tostring(math.round(buyPartialTgt,0)) + " (" + str.tostring(math.round(buyPartialTgt-close,1)) + "pt)", text_color=color.lime, text_size=tblSize)
        r += 1
        
        table.cell(dash, 0, r, "Target 2", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, str.tostring(math.round(buyTarget2,0)) + " (" + str.tostring(math.round(buyTarget2-close,1)) + "pt)", text_color=color.green, text_size=tblSize)
        r += 1
        
        table.cell(dash, 0, r, "Risk:Reward", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, "1:" + str.tostring(math.round(rrRatio,1)), text_color=color.white, text_size=tblSize)
        r += 1
    
    else if strategy.position_size < 0
        table.cell(dash, 0, r, "Entry Price", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, str.tostring(math.round(strategy.opentrades.entry_price(0),0)), text_color=color.white, text_size=tblSize)
        r += 1
        
        table.cell(dash, 0, r, "Stop Loss", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, str.tostring(math.round(sellSL,0)) + " (" + str.tostring(math.round(sellSL-close,1)) + "pt)", text_color=color.red, text_size=tblSize)
        r += 1
        
        table.cell(dash, 0, r, "Target 1", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, str.tostring(math.round(sellPartialTgt,0)) + " (" + str.tostring(math.round(close-sellPartialTgt,1)) + "pt)", text_color=color.lime, text_size=tblSize)
        r += 1
        
        table.cell(dash, 0, r, "Target 2", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, str.tostring(math.round(sellTarget2,0)) + " (" + str.tostring(math.round(close-sellTarget2,1)) + "pt)", text_color=color.green, text_size=tblSize)
        r += 1
        
        table.cell(dash, 0, r, "Risk:Reward", text_color=color.white, text_size=tblSize)
        table.cell(dash, 1, r, "1:" + str.tostring(math.round(rrRatio,1)), text_color=color.white, text_size=tblSize)
        r += 1
    
    // Options Module
    table.cell(dash, 0, r, "📊 OPTIONS (WEEKLY)", text_color=color.white, bgcolor=color.new(color.orange,30), text_size=tblSize)
    table.cell(dash, 1, r, "STRIKE", text_color=color.white, bgcolor=color.new(color.orange,30), text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "ATM Strike", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(atmStrike), text_color=color.white, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Bull Call Spread", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, "B" + str.tostring(bullCallLong) + "/S" + str.tostring(bullCallShort), text_color=color.green, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Bear Put Spread", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, "B" + str.tostring(bearPutShort) + "/S" + str.tostring(bearPutLong), text_color=color.red, text_size=tblSize)
    r += 1
    
    // Volume & Volatility
    table.cell(dash, 0, r, "📈 FILTERS", text_color=color.white, bgcolor=color.new(color.navy,20), text_size=tblSize)
    table.cell(dash, 1, r, "STATUS", text_color=color.white, bgcolor=color.new(color.navy,20), text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Volume", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, volumeStatus, text_color=volOK?color.green:color.red, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Volatility", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, "ATR: " + str.tostring(math.round(atrVal,1)), text_color=volatilityOK?color.green:color.red, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Session", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, inSession ? "OPEN ✅" : "CLOSED ❌", text_color=inSession?color.green:color.red, text_size=tblSize)
    r += 1
    
    // Performance
    table.cell(dash, 0, r, "📊 PERFORMANCE", text_color=color.white, bgcolor=color.new(color.purple,30), text_size=tblSize)
    table.cell(dash, 1, r, "", text_color=color.white, bgcolor=color.new(color.purple,30), text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Total Trades", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(totalTrades), text_color=color.white, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Win Rate", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(math.round(winRatePct,1)) + "% (" + str.tostring(winTrades) + "/" + str.tostring(totalTrades) + ")", text_color=winRatePct>=50?color.green:color.red, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Net P&L", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(math.round(netProfitPct,2)) + "%", text_color=netProfitPct>=0?color.green:color.red, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Max Drawdown", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(math.round(maxDDPct,2)) + "%", text_color=maxDDPct<=5?color.green:color.orange, text_size=tblSize)
    r += 1
    
    // Daily Limits
    table.cell(dash, 0, r, "🛡️ DAILY LIMITS", text_color=color.white, bgcolor=color.new(color.red,20), text_size=tblSize)
    table.cell(dash, 1, r, "", text_color=color.white, bgcolor=color.new(color.red,20), text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Trades Today", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(todayTrades) + "/" + str.tostring(maxTradesPerDay), text_color=todayTrades < maxTradesPerDay?color.green:color.red, text_size=tblSize)
    r += 1
    
    table.cell(dash, 0, r, "Daily P&L", text_color=color.white, text_size=tblSize)
    table.cell(dash, 1, r, str.tostring(math.round(dailyLossPct,2)) + "%", text_color=dailyLossPct>=-maxLossPerDay?color.green:color.red, text_size=tblSize)
    r += 1

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 14: ALERTS
// ═══════════════════════════════════════════════════════════════════════════

if enableAlerts
    if buyTrigger
        alert("🟢 BUY SIGNAL - Confidence: " + str.tostring(confidenceBuy) + "% (" + tradeQuality + ")\nPrice: " + str.tostring(math.round(close,0)) + " | SL: " + str.tostring(math.round(buySL,0)) + " | T1: " + str.tostring(math.round(buyPartialTgt,0)) + " | T2: " + str.tostring(math.round(buyTarget2,0)) + "\nATM CE: " + str.tostring(atmStrike), alert.freq_once_per_bar_close)
    
    if sellTrigger
        alert("🔴 SELL SIGNAL - Confidence: " + str.tostring(confidenceBuy) + "% (" + tradeQuality + ")\nPrice: " + str.tostring(math.round(close,0)) + " | SL: " + str.tostring(math.round(sellSL,0)) + " | T1: " + str.tostring(math.round(sellPartialTgt,0)) + " | T2: " + str.tostring(math.round(sellTarget2,0)) + "\nATM PE: " + str.tostring(atmStrike), alert.freq_once_per_bar_close)

// Session Background
bgcolor(inSession ? color.new(color.blue, 97) : na)
