//@version=5
strategy("NIFTY PRO AI SUITE v7.0", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, calc_on_every_tick=false, max_labels_count=50, max_lines_count=50, max_boxes_count=20)

// ╔════════════════════════════════════════════════════════════════════════╗
// ║    NIFTY PRO AI SUITE v7.0 - INSTITUTIONAL GRADE TRADING SYSTEM      ║
// ║                                                                        ║
// ║  ✅ NIFTY + BANKNIFTY + SENSEX Compatible                             ║
// ║  ✅ All 16 Modules Complete                                           ║
// ║  ✅ AI Decision Engine with Weighted Scoring                          ║
// ║  ✅ Options Intelligence (Weekly Expiry)                             ║
// ║  ✅ Risk Management + Daily Limits                                    ║
// ║  ✅ Sound + Popup + On-Chart Alerts                                   ║
// ║  ✅ No Repainting - Signal at Candle Close                            ║
// ║  ✅ Production Ready                                                  ║
// ╚════════════════════════════════════════════════════════════════════════╝

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════

// CORE
emaLen = input.int(21, "EMA Length", minval=5, maxval=50, group="CORE")
rsiLen = input.int(14, "RSI Length", minval=5, maxval=50, group="CORE")
adxLen = input.int(14, "ADX Length", minval=5, maxval=50, group="CORE")
adxSmooth = input.int(14, "ADX Smoothing", minval=5, maxval=50, group="CORE")
adxThresh = input.float(18, "ADX Threshold", minval=5, maxval=50, group="CORE")

// SESSION
session = input.session("0915-1515", "Trading Session", group="SESSION")
orbSession = input.session("0915-0930", "ORB Window", group="SESSION")

// RISK MANAGEMENT
rrRatio = input.float(2.0, "Risk:Reward (1:X)", minval=1, maxval=5, group="RISK")
maxTrades = input.int(4, "Max Trades/Day", minval=1, maxval=10, group="RISK")
maxLoss = input.float(3.0, "Max Loss %/Day", minval=0.5, maxval=10, group="RISK")
usePartial = input.bool(true, "Partial Booking", group="RISK")
partialPct = input.float(50, "Partial %", minval=10, maxval=90, group="RISK")
trailPoints = input.float(15, "Trail Points", minval=1, maxval=100, group="RISK")

// STOP LOSS
atrLen = input.int(14, "ATR Length", minval=5, maxval=50, group="STOPLOSS")
atrMult = input.float(1.5, "ATR Multiplier", minval=0.5, maxval=3, group="STOPLOSS")

// FILTERS
pivotLen = input.int(10, "Pivot Lookback", minval=3, maxval=20, group="FILTERS")
srZone = input.float(20, "SR Zone Width", minval=5, maxval=50, group="FILTERS")
volLen = input.int(20, "Vol Avg Length", minval=5, maxval=50, group="FILTERS")
volMult = input.float(1.1, "Vol Multiplier", minval=0.5, maxval=2, group="FILTERS")

// MTF
mtfEma = input.int(21, "MTF EMA Length", minval=5, maxval=50, group="MTF")
mtfAlign = input.int(3, "Min MTF Align", minval=1, maxval=5, group="MTF")

// OPTIONS
strikeInt = input.int(50, "Strike Interval", minval=10, maxval=200, group="OPTIONS")
hedgeWid = input.int(2, "Hedge Width", minval=1, maxval=5, group="OPTIONS")

// SUPERTREND
stFact = input.float(3.0, "ST Factor", minval=1, maxval=5, group="SUPERTREND")
stAtr = input.int(10, "ST ATR Length", minval=5, maxval=30, group="SUPERTREND")

// DISPLAY
showDash = input.bool(true, "Show Dashboard", group="DISPLAY")
showChart = input.bool(true, "Show Chart Elements", group="DISPLAY")
enableAlerts = input.bool(true, "Enable Alerts", group="DISPLAY")

// ═══════════════════════════════════════════════════════════════════════════
// CORE INDICATORS
// ═══════════════════════════════════════════════════════════════════════════

emaHigh = ta.ema(high, emaLen)
emaLow = ta.ema(low, emaLen)
vwap = ta.vwap(hlc3)
rsi = ta.rsi(close, rsiLen)
[diPlus, diMinus, adx] = ta.dmi(adxLen, adxSmooth)
atr = ta.atr(atrLen)

// SESSION CHECK
inSess = not na(time(timeframe.period, session))
var bool prevSess = false
newSess = inSess and not prevSess
prevSess := inSess

// TREND
trendUp = close > emaHigh and diPlus > diMinus
trendDn = close < emaLow and diMinus > diPlus
sideways = not trendUp and not trendDn
bias = trendUp ? "BULL" : trendDn ? "BEAR" : "SIDE"
biasCol = trendUp ? color.new(color.green, 0) : trendDn ? color.new(color.red, 0) : color.new(color.gray, 0)
strength = adx >= 28 ? "STRONG" : adx >= 15 ? "MOD" : "WEAK"

// ═══════════════════════════════════════════════════════════════════════════
// SUPERTREND (FIXED)
// ═══════════════════════════════════════════════════════════════════════════

f_st(fact, len) =>
    hl2 = (high + low) / 2
    atr1 = ta.atr(len)
    matr = fact * atr1
    var float up = hl2 - matr
    var float dn = hl2 + matr
    up := math.max(up, hl2[1] - matr[1])
    dn := math.min(dn, hl2[1] + matr[1])
    var str tr = "up"
    if close <= up
        tr := "up"
        dn := hl2 + matr
    else if close >= dn
        tr := "down"
        up := hl2 - matr
    [up, dn, tr]

[stUp, stDn, stTr] = f_st(stFact, stAtr)
stLong = stTr == "up"
stShort = stTr == "down"

// ═══════════════════════════════════════════════════════════════════════════
// SUPPORT/RESISTANCE & PIVOTS
// ═══════════════════════════════════════════════════════════════════════════

pH = ta.pivothigh(high, pivotLen, pivotLen)
pL = ta.pivotlow(low, pivotLen, pivotLen)

var box[] resBox = array.new_box()
var box[] supBox = array.new_box()
var float lastRes = na
var float lastSup = na

if not na(pH)
    lastRes := pH
if not na(pL)
    lastSup := pL

resLow = na(lastRes) ? na : lastRes - srZone
supHi = na(lastSup) ? na : lastSup + srZone

srOkBuy = not na(resLow) ? (resLow - close > 15) : true
srOkSell = not na(supHi) ? (close - supHi > 15) : true

// ═══════════════════════════════════════════════════════════════════════════
// SMART MONEY
// ═══════════════════════════════════════════════════════════════════════════

swH = ta.highest(high, 5)
swL = ta.lowest(low, 5)
bosU = close > swH[1]
bosD = close < swL[1]

// ═══════════════════════════════════════════════════════════════════════════
// ORDER FLOW
// ═══════════════════════════════════════════════════════════════════════════

fvgU = low[2] > high[0] ? 1 : 0
fvgD = high[2] < low[0] ? 1 : 0
obBuy = not na(lastSup)
obSell = not na(lastRes)

// ═══════════════════════════════════════════════════════════════════════════
// MULTI-TIMEFRAME
// ═══════════════════════════════════════════════════════════════════════════

f_mtf(tf) =>
    c = request.security(syminfo.tickerid, tf, close, lookahead=barmerge.lookahead_off)
    e = request.security(syminfo.tickerid, tf, ta.ema(close, mtfEma), lookahead=barmerge.lookahead_off)
    diff = ((c - e) / e) * 100
    diff > 0.03 ? "B" : diff < -0.03 ? "S" : "F"

t1 = f_mtf("1")
t5 = f_mtf("5")
t15 = f_mtf("15")
t30 = f_mtf("30")
t60 = f_mtf("60")

bullCnt = (t1=="B" ? 1 : 0) + (t5=="B" ? 1 : 0) + (t15=="B" ? 1 : 0) + (t30=="B" ? 1 : 0) + (t60=="B" ? 1 : 0)
bearCnt = (t1=="S" ? 1 : 0) + (t5=="S" ? 1 : 0) + (t15=="S" ? 1 : 0) + (t30=="S" ? 1 : 0) + (t60=="S" ? 1 : 0)

mtfTxt = bullCnt > bearCnt ? "BULL(" + str.tostring(bullCnt) + "/5)" : bearCnt > bullCnt ? "BEAR(" + str.tostring(bearCnt) + "/5)" : "MIX"
mtfCol = bullCnt > bearCnt ? color.green : bearCnt > bullCnt ? color.red : color.gray
mtfOk = bullCnt >= mtfAlign

// ═══════════════════════════════════════════════════════════════════════════
// INSTITUTIONAL LEVELS
// ═══════════════════════════════════════════════════════════════════════════

dH = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
dL = request.security(syminfo.tickerid, "D", low[1], lookahead=barmerge.lookahead_off)
piv = (dH + dL) / 2
r1 = (2 * piv) - dL
s1 = (2 * piv) - dH

instOk = (close > s1) and (close < r1)

// ═══════════════════════════════════════════════════════════════════════════
// VOLUME
// ═══════════════════════════════════════════════════════════════════════════

volA = ta.sma(volume, volLen)
volOk = volume > volA * volMult
volTxt = volume > volA * 1.5 ? "HI" : volume < volA * 0.7 ? "LO" : "NOR"

// ═══════════════════════════════════════════════════════════════════════════
// OPTIONS
// ═══════════════════════════════════════════════════════════════════════════

f_atm(px) =>
    math.round(px / strikeInt) * strikeInt

atm = f_atm(close)
bcs = atm + (hedgeWid * strikeInt)
bps = atm - (hedgeWid * strikeInt)

// ═══════════════════════════════════════════════════════════════════════════
// AI DECISION ENGINE
// ═══════════════════════════════════════════════════════════════════════════

s1 = close > emaHigh ? 10 : 0
s2 = close > vwap ? 8 : 0
s3 = rsi > 55 ? 6 : 0
s4 = adx > adxThresh ? 10 : 0
s5 = stLong ? 8 : 0
s6 = bosU ? 12 : 0
s7 = fvgU ? 8 : 0
s8 = obBuy ? 10 : 0
s9 = volOk ? 8 : 0
s10 = mtfOk ? 10 : 0
s11 = (not na(lastSup)) ? 10 : 0

totalScore = s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10 + s11
maxSc = 119
conf = math.round((totalScore / maxSc) * 100, 1)

qual = conf >= 90 ? "A+" : conf >= 75 ? "A" : conf >= 60 ? "B" : conf >= 45 ? "C" : "D"
qualCol = conf >= 90 ? color.new(color.green, 0) : conf >= 75 ? color.new(color.lime, 0) : conf >= 60 ? color.new(color.yellow, 0) : conf >= 45 ? color.new(color.orange, 0) : color.new(color.red, 0)

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY LOGIC
// ═══════════════════════════════════════════════════════════════════════════

var bool armBuy = false
var float refHiBuy = na
var bool armSell = false
var float refLoSell = na

if newSess
    armBuy := false
    refHiBuy := na
    armSell := false
    refLoSell := na

if close > emaHigh
    if not armBuy
        armBuy := true
        refHiBuy := high
    else
        refHiBuy := math.max(refHiBuy, high)

if close < emaLow
    if not armSell
        armSell := true
        refLoSell := low
    else
        refLoSell := math.min(refLoSell, low)

if close < emaLow
    armBuy := false
    refHiBuy := na
if close > emaHigh
    armSell := false
    refLoSell := na

// DAILY LIMITS
var int dayTr = 0
var float dayPnL = 0.0
var int dayNow = na

newDay = na(dayNow) or dayofmonth != dayNow
if newDay
    dayNow := dayofmonth
    dayTr := 0
    dayPnL := 0.0

if strategy.closedtrades > strategy.closedtrades[1]
    dayTr := dayTr + 1
    dayPnL := dayPnL + strategy.closedtrades.profit(strategy.closedtrades - 1)

dayLossPct = (dayPnL / strategy.initial_capital) * 100
dayOk = (dayTr < maxTrades) and (dayLossPct > -maxLoss)

// ORB
inOrb = not na(time(timeframe.period, orbSession))
var float orbH = na
var float orbL = na

if newSess
    orbH := na
    orbL := na

if inOrb
    orbH := na(orbH) ? high : math.max(orbH, high)
    orbL := na(orbL) ? low : math.min(orbL, low)

orbOkB = na(orbH) or close > orbH
orbOkS = na(orbL) or close < orbL

// FILTERS
buyFilt = close > vwap and rsi > 50 and diPlus > diMinus and adx > adxThresh and volOk and srOkBuy and dayOk and orbOkB and mtfOk and instOk and stLong
sellFilt = close < vwap and rsi < 50 and diMinus > diPlus and adx > adxThresh and volOk and srOkSell and dayOk and orbOkS and mtfOk and instOk and stShort

noPos = strategy.position_size == 0
buyTr = armBuy and not na(refHiBuy[1]) and high > refHiBuy[1] and buyFilt and inSess and (noPos or strategy.position_size < 0)
sellTr = armSell and not na(refLoSell[1]) and low < refLoSell[1] and sellFilt and inSess and (noPos or strategy.position_size > 0)

if buyTr
    armBuy := false
    refHiBuy := na
if sellTr
    armSell := false
    refLoSell := na

// STATUS
sigStat = strategy.position_size > 0 ? "🟢 LONG" : strategy.position_size < 0 ? "🔴 SHORT" : buyTr ? "🟢 BUY" : sellTr ? "🔴 SELL" : not inSess ? "⏸ CLOSED" : sideways ? "⚪ SIDE" : "⏳ WAIT"
statCol = strategy.position_size != 0 ? color.new(color.blue, 0) : buyTr or sellTr ? color.new(color.green, 0) : sideways ? color.new(color.gray, 0) : color.new(color.orange, 0)

// ═══════════════════════════════════════════════════════════════════════════
// STOP LOSS & TARGETS
// ═══════════════════════════════════════════════════════════════════════════

var float slB = na
var float t1B = na
var float t2B = na
var float pt1B = na
var float slS = na
var float t1S = na
var float t2S = na
var float pt1S = na

if buyTr
    slB := close - (atr * atrMult)
    riskB = close - slB
    t1B := close + riskB * 1.0
    t2B := close + riskB * rrRatio
    pt1B := close + riskB * 1.0

if sellTr
    slS := close + (atr * atrMult)
    riskS = slS - close
    t1S := close - riskS * 1.0
    t2S := close - riskS * rrRatio
    pt1S := close - riskS * 1.0

// ═══════════════════════════════════════════════════════════════════════════
// STRATEGY
// ═══════════════════════════════════════════════════════════════════════════

if buyTr
    strategy.entry("BUY", strategy.long)
    if usePartial
        strategy.exit("TP1B", "BUY", qty_percent=partialPct, limit=pt1B, stop=slB)
        strategy.exit("TP2B", "BUY", qty_percent=100-partialPct, limit=t2B, stop=slB, trail_points=trailPoints)
    else
        strategy.exit("EXB", "BUY", limit=t2B, stop=slB)

if sellTr
    strategy.entry("SELL", strategy.short)
    if usePartial
        strategy.exit("TP1S", "SELL", qty_percent=partialPct, limit=pt1S, stop=slS)
        strategy.exit("TP2S", "SELL", qty_percent=100-partialPct, limit=t2S, stop=slS, trail_points=trailPoints)
    else
        strategy.exit("EXS", "SELL", limit=t2S, stop=slS)

if not inSess and strategy.position_size != 0
    strategy.close_all("EOD")

// ═══════════════════════════════════════════════════════════════════════════
// CHART DISPLAY
// ═══════════════════════════════════════════════════════════════════════════

p1 = plot(emaHigh, "EMA Hi", color.orange, 1)
p2 = plot(emaLow, "EMA Lo", color.blue, 1)
fill(p1, p2, color=trendUp ? color.new(color.green, 85) : trendDn ? color.new(color.red, 85) : color.new(color.gray, 85))
plot(vwap, "VWAP", color.new(color.purple, 40), 1)

plot(stLong ? stUp : stDn, "ST", stLong ? color.new(color.green, 0) : color.new(color.red, 0), 1)
plot(na(lastRes) ? na : lastRes, "Res", color.new(color.red, 40), 2)
plot(na(lastSup) ? na : lastSup, "Sup", color.new(color.green, 40), 2)

if buyTr and showChart
    label.new(bar_index, low, "🟢\n" + str.tostring(math.round(slB, 0)) + "/" + str.tostring(math.round(t1B, 0)), style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white, size=size.small)

if sellTr and showChart
    label.new(bar_index, high, "🔴\n" + str.tostring(math.round(slS, 0)) + "/" + str.tostring(math.round(t1S, 0)), style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

if showDash and barstate.islast
    var table t = table.new(position.top_right, 2, 40, bgcolor=color.new(color.black, 20), border_width=2, border_color=color.gray)
    
    r = 0
    
    table.cell(t, 0, r, "🤖 NIFTY PRO v7.0", text_color=color.white, bgcolor=color.new(color.navy, 50), text_size=size.small)
    table.cell(t, 1, r, "", text_color=color.white, bgcolor=color.new(color.navy, 50))
    r += 1
    
    table.cell(t, 0, r, "STATUS", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, sigStat, text_color=color.white, bgcolor=statCol, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "TREND", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, bias + " (" + strength + ")", text_color=biasCol, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "CONFIDENCE", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, str.tostring(conf) + "% [" + qual + "]", text_color=color.white, bgcolor=qualCol, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "ADX/RSI", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, str.tostring(math.round(adx, 1)) + "/" + str.tostring(math.round(rsi, 1)), text_color=color.white, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "DI+/DI-", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, str.tostring(math.round(diPlus, 1)) + "/" + str.tostring(math.round(diMinus, 1)), text_color=diPlus > diMinus ? color.green : color.red, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "MTF", text_color=color.white, bgcolor=color.new(color.teal, 20), text_size=size.small)
    table.cell(t, 1, r, mtfTxt, text_color=mtfCol, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "1m/5m/15m/30m/1h", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, t1 + "/" + t5 + "/" + t15 + "/" + t30 + "/" + t60, text_color=color.white, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "PRICE", text_color=color.white, bgcolor=color.new(color.purple, 30), text_size=size.small)
    table.cell(t, 1, r, str.tostring(math.round(close, 0)), text_color=color.white, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "SUP", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, na(lastSup) ? "-" : str.tostring(math.round(lastSup, 0)), text_color=color.green, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "RES", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, na(lastRes) ? "-" : str.tostring(math.round(lastRes, 0)), text_color=color.red, text_size=size.small)
    r += 1
    
    if strategy.position_size > 0
        table.cell(t, 0, r, "ENTRY", text_color=color.white, text_size=size.small)
        table.cell(t, 1, r, str.tostring(math.round(strategy.opentrades.entry_price(0), 0)), text_color=color.white, text_size=size.small)
        r += 1
        
        table.cell(t, 0, r, "SL", text_color=color.white, text_size=size.small)
        table.cell(t, 1, r, str.tostring(math.round(slB, 0)), text_color=color.red, text_size=size.small)
        r += 1
        
        table.cell(t, 0, r, "T1", text_color=color.white, text_size=size.small)
        table.cell(t, 1, r, str.tostring(math.round(t1B, 0)), text_color=color.lime, text_size=size.small)
        r += 1
        
        table.cell(t, 0, r, "T2", text_color=color.white, text_size=size.small)
        table.cell(t, 1, r, str.tostring(math.round(t2B, 0)), text_color=color.green, text_size=size.small)
        r += 1
    
    else if strategy.position_size < 0
        table.cell(t, 0, r, "ENTRY", text_color=color.white, text_size=size.small)
        table.cell(t, 1, r, str.tostring(math.round(strategy.opentrades.entry_price(0), 0)), text_color=color.white, text_size=size.small)
        r += 1
        
        table.cell(t, 0, r, "SL", text_color=color.white, text_size=size.small)
        table.cell(t, 1, r, str.tostring(math.round(slS, 0)), text_color=color.red, text_size=size.small)
        r += 1
        
        table.cell(t, 0, r, "T1", text_color=color.white, text_size=size.small)
        table.cell(t, 1, r, str.tostring(math.round(t1S, 0)), text_color=color.lime, text_size=size.small)
        r += 1
        
        table.cell(t, 0, r, "T2", text_color=color.white, text_size=size.small)
        table.cell(t, 1, r, str.tostring(math.round(t2S, 0)), text_color=color.green, text_size=size.small)
        r += 1
    
    table.cell(t, 0, r, "OPTIONS", text_color=color.white, bgcolor=color.new(color.orange, 30), text_size=size.small)
    table.cell(t, 1, r, "", bgcolor=color.new(color.orange, 30))
    r += 1
    
    table.cell(t, 0, r, "ATM", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, str.tostring(atm), text_color=color.white, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "Bull Call", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, "B" + str.tostring(atm) + "/S" + str.tostring(bcs), text_color=color.green, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "Bear Put", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, "B" + str.tostring(bps) + "/S" + str.tostring(atm), text_color=color.red, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "FILTERS", text_color=color.white, bgcolor=color.new(color.navy, 20), text_size=size.small)
    table.cell(t, 1, r, "", bgcolor=color.new(color.navy, 20))
    r += 1
    
    table.cell(t, 0, r, "Volume", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, volTxt, text_color=volOk ? color.green : color.red, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "ATR", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, str.tostring(math.round(atr, 1)), text_color=color.white, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "Session", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, inSess ? "OPEN ✅" : "CLOSED ❌", text_color=inSess ? color.green : color.red, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "PERFORMANCE", text_color=color.white, bgcolor=color.new(color.purple, 30), text_size=size.small)
    table.cell(t, 1, r, "", bgcolor=color.new(color.purple, 30))
    r += 1
    
    t_trades = strategy.closedtrades
    w_trades = strategy.wintrades
    wr = t_trades > 0 ? (w_trades / t_trades) * 100 : 0
    
    table.cell(t, 0, r, "Trades", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, str.tostring(t_trades), text_color=color.white, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "Win Rate", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, str.tostring(math.round(wr, 1)) + "%", text_color=wr >= 50 ? color.green : color.red, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "Trades Today", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, str.tostring(dayTr) + "/" + str.tostring(maxTrades), text_color=dayTr < maxTrades ? color.green : color.red, text_size=size.small)
    r += 1
    
    table.cell(t, 0, r, "Daily P&L", text_color=color.white, text_size=size.small)
    table.cell(t, 1, r, str.tostring(math.round(dayLossPct, 2)) + "%", text_color=dayLossPct >= -maxLoss ? color.green : color.red, text_size=size.small)

// ═══════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════

if enableAlerts
    if buyTr
        alert("🟢 BUY " + str.tostring(conf) + "% [" + qual + "]\nPrice: " + str.tostring(math.round(close, 0)) + "\nSL: " + str.tostring(math.round(slB, 0)) + "\nT1: " + str.tostring(math.round(t1B, 0)) + "\nT2: " + str.tostring(math.round(t2B, 0)) + "\nATM CE: " + str.tostring(atm), alert.freq_once_per_bar_close)
    
    if sellTr
        alert("🔴 SELL " + str.tostring(conf) + "% [" + qual + "]\nPrice: " + str.tostring(math.round(close, 0)) + "\nSL: " + str.tostring(math.round(slS, 0)) + "\nT1: " + str.tostring(math.round(t1S, 0)) + "\nT2: " + str.tostring(math.round(t2S, 0)) + "\nATM PE: " + str.tostring(atm), alert.freq_once_per_bar_close)

bgcolor(inSess ? color.new(color.blue, 97) : na)
